<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- X2b-2: BLE permissions for the pairing ceremony ONLY (advertise + scan + connect while
         the pairing screen is open). SCAN is neverForLocation — the ceremony derives no location.
         Legacy trio for API 26-30 (lab fleet is 33/36; minSdk floor keeps them). Mesh transport
         (foreground service etc.) arrives in X3 with its own justification. -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" android:maxSdkVersion="30" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <application
        android:label="polleneus"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.Polleneus"
        android:allowBackup="false">

        <!-- allowBackup=false is load-bearing: cloud backup of identity/messages would
             contradict local-only deletion (design system §5 / settings "deliberate absences"). -->

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
